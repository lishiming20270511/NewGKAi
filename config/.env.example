# =============================================
# AI高考志愿规划师 — Environment Variables
# Copy this file to .env and fill in values
# =============================================

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gaokao_ai
DB_USER=gaokao_user
DB_PASSWORD=your_db_password_here

# MySQL Connection Pool (T1.1)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# --- Redis (T1.1) ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- JWT ---
JWT_SECRET=change_me_to_a_strong_random_secret_64chars
INTERNAL_JWT_SECRET=change_me_to_internal_crawler_secret_32chars

# --- LLM API (DeepSeek / Claude / GPT - pick one via LLM_PROVIDER) ---
LLM_PROVIDER=deepseek
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Anthropic (fallback)
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Aliyun OSS ---
OSS_ACCESS_KEY_ID=your_oss_key_id
OSS_ACCESS_KEY_SECRET=your_oss_secret
OSS_BUCKET_NAME=gaokaobaoming
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
